page {
  height: 100vh;
  background: #ffffff;
  color: #1f2937;
  display: flex;
  flex-direction: column;
}

.page {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
}

.scrollarea {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  overflow-x: hidden;
}

.page-container {
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  min-width: 0;
}

.hero-card {
  background: transparent;
  border-radius: 28rpx;
  padding: 28rpx 24rpx;
}

.hero-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
}

.title {
  font-size: 56rpx;
  font-weight: 700;
  line-height: 1.2;
}

.desc {
  margin-top: 18rpx;
  color: #4b5563;
  font-size: 30rpx;
  line-height: 1.6;
}

.bot-avatar {
  width: 110rpx;
  height: 110rpx;
  border-radius: 55rpx;
  background: #e7f0ff;
  display: flex;
  justify-content: center;
  align-items: center;
  overflow: hidden;
  flex: none;
}

.bot-avatar-img {
  width: 100%;
  height: 100%;
  display: block;
}

.hint-row {
  margin-top: 26rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.hint-label {
  color: #374151;
  font-size: 30rpx;
  font-weight: 600;
}

.switch-text {
  color: #6b7280;
  font-size: 26rpx;
}

.suggestion-list {
  margin-top: 14rpx;
}

.suggestion-item {
  background: #f9fbff;
  border: 1rpx solid #edf1f6;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.left {
  display: flex;
  align-items: center;
  min-width: 0;
  flex: 1;
}

.emoji {
  font-size: 34rpx;
  margin-right: 10rpx;
  flex: none;
}

.tag {
  font-size: 28rpx;
  color: #2563eb;
  font-weight: 700;
  margin-right: 10rpx;
  flex: none;
}

.s-text {
  font-size: 27rpx;
  color: #1f2937;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.arrow {
  font-size: 36rpx;
  color: #9ca3af;
  margin-left: 8rpx;
}

.chat-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.msg {
  max-width: 78%;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  font-size: 29rpx;
  line-height: 1.5;
  word-break: break-all;
  overflow: hidden;
}

.msg-text {
  display: block;
  max-width: 100%;
  overflow-wrap: break-word;
  word-break: break-word;
}

.assistant {
  align-self: flex-start;
  max-width: 94%;
  background: transparent;
  color: #111827;
  padding: 8rpx 6rpx;
  border-radius: 0;
}

.user {
  align-self: flex-end;
  background: #e5e7eb;
  color: #111827;
}

.loading {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 26rpx;
}

.input-area {
  background: #ffffff;
  padding: 8rpx 12rpx 10rpx;
}

.input-card {
  border: 2rpx solid #d9dde5;
  border-radius: 38rpx;
  background: #fff;
  padding: 16rpx 18rpx 10rpx;
}

.input {
  width: 100%;
  min-height: 170rpx;
  max-height: 300rpx;
  background: transparent;
  border-radius: 0;
  padding: 6rpx 10rpx;
  box-sizing: border-box;
  font-size: 31rpx;
  line-height: 1.4;
  color: #2a3140;
}

.input-footer {
  margin-top: 6rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 8rpx 4rpx;
}

.counter {
  color: #9aa3af;
  font-size: 29rpx;
}

.input-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.plus-btn {
  font-size: 44rpx;
  line-height: 1;
  color: #727b8a;
  padding: 0 4rpx;
}

.action-divider {
  width: 2rpx;
  height: 36rpx;
  background: #d8dde6;
}

.send-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 30rpx;
  background: #eceff4;
  display: flex;
  align-items: center;
  justify-content: center;
}

.send-icon.disabled {
  opacity: 1;
}

.send-icon-text {
  font-size: 28rpx;
  color: #c4cbd6;
  transform: translateX(2rpx);
}

.send-icon.active .send-icon-text {
  color: #7f8897;
}

.input-tip {
  text-align: center;
  color: #98a1af;
  font-size: 22rpx;
  margin-bottom: 4rpx;
}
