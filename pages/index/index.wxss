page {
  height: 100vh;
  background: #ffffff;
  color: #1f2937;
  display: flex;
  flex-direction: column;
}

.page {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
}

.scrollarea {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  overflow-x: hidden;
}

.page-container {
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  min-width: 0;
}

.hero-card {
  background: transparent;
  border-radius: 28rpx;
  padding: 28rpx 24rpx;
}

.hero-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
}

.title {
  font-size: 56rpx;
  font-weight: 700;
  line-height: 1.2;
}

.desc {
  margin-top: 18rpx;
  color: #4b5563;
  font-size: 30rpx;
  line-height: 1.6;
}

.bot-avatar {
  width: 110rpx;
  height: 110rpx;
  border-radius: 55rpx;
  background: #e7f0ff;
  display: flex;
  justify-content: center;
  align-items: center;
  overflow: visible;
  flex: none;
  position: relative;
}

.bot-avatar-img {
  width: 100%;
  height: 100%;
  display: block;
  border-radius: 55rpx;
}

.hi-badge {
  position: absolute;
  left: -34rpx;
  top: -16rpx;
  z-index: 3;
  min-width: 46rpx;
  height: 36rpx;
  line-height: 36rpx;
  padding: 0 12rpx;
  border-radius: 20rpx;
  text-align: center;
  background: #ff7f57;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  transform: rotate(-8deg);
  box-shadow: 0 4rpx 10rpx rgba(255, 127, 87, 0.35);
}

.hint-row {
  margin-top: 26rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.hint-label {
  color: #374151;
  font-size: 26rpx;
  font-weight: 400;
}

.switch-text {
  color: #6b7280;
  font-size: 26rpx;
}

.switch-action {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
}

.switch-icon {
  color: #6b7280;
  font-size: 28rpx;
  line-height: 1;
  transform: translateY(-1rpx);
}

.suggestion-list {
  margin-top: 14rpx;
}

.suggestion-item {
  background: #f9fbff;
  border: 1rpx solid #edf1f6;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.left {
  display: flex;
  align-items: center;
  min-width: 0;
  flex: 1;
}

.emoji {
  font-size: 34rpx;
  margin-right: 10rpx;
  flex: none;
}

.tag {
  font-size: 28rpx;
  color: #2563eb;
  font-weight: 700;
  margin-right: 10rpx;
  flex: none;
}

.s-text {
  font-size: 27rpx;
  color: #1f2937;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.arrow {
  font-size: 36rpx;
  color: #9ca3af;
  margin-left: 8rpx;
}

.chat-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.msg {
  max-width: 78%;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  font-size: 29rpx;
  line-height: 1.5;
  word-break: break-all;
  overflow: visible;
}

.msg-text {
  display: block;
  width: 100%;
  max-width: 100%;
  white-space: normal;
  overflow-wrap: break-word;
  word-break: break-all;
}

.assistant {
  align-self: flex-start;
  max-width: 100%;
  width: 100%;
  background: transparent;
  color: #111827;
  padding: 8rpx 6rpx;
  border-radius: 0;
}

.user {
  align-self: flex-end;
  background: #f1f3f6;
  color: #111827;
  white-space: normal;
}

.user .msg-text {
  white-space: pre-wrap;
  word-break: break-all;
}

.loading {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 26rpx;
  display: flex;
  align-items: center;
}

.dot {
  display: inline-block;
  width: 14rpx;
  font-size: 30rpx;
  line-height: 1;
  text-align: center;
  animation: dot-wave 1s infinite ease-in-out;
}

.dot1 {
  animation-delay: 0s;
}

.dot2 {
  animation-delay: 0.15s;
}

.dot3 {
  animation-delay: 0.3s;
}

@keyframes dot-wave {
  0%,
  60%,
  100% {
    opacity: 0.2;
    transform: translateY(0);
  }
  30% {
    opacity: 1;
    transform: translateY(-4rpx);
  }
}

.input-area {
  background: #ffffff;
  padding: 8rpx 12rpx 10rpx;
  position: relative;
}

.input-card {
  border: 2rpx solid #d9dde5;
  border-radius: 38rpx;
  background: #fff;
  padding: 16rpx 18rpx 10rpx;
}

.input {
  width: 100%;
  min-height: 170rpx;
  max-height: 300rpx;
  background: transparent;
  border-radius: 0;
  padding: 6rpx 10rpx;
  box-sizing: border-box;
  font-size: 31rpx;
  line-height: 1.4;
  color: #2a3140;
}

.input-footer {
  margin-top: 6rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 8rpx 4rpx;
}

.counter {
  color: #9aa3af;
  font-size: 29rpx;
}

.input-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.plus-btn {
  font-size: 44rpx;
  line-height: 1;
  color: #727b8a;
  padding: 0 4rpx;
  min-width: 44rpx;
  text-align: center;
}

.quick-menu {
  position: absolute;
  right: 88rpx;
  bottom: 124rpx;
  width: 200rpx;
  background: #ffffff;
  border: 2rpx solid #dfe3ea;
  border-radius: 22rpx;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.08);
  overflow: hidden;
  z-index: 30;
}

.quick-item {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  padding: 18rpx 18rpx;
}

.quick-text {
  font-size: 28rpx;
  color: #111827;
  font-weight: 400;
  text-align: left;
}

.action-divider {
  width: 2rpx;
  height: 36rpx;
  background: #d8dde6;
}

.send-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 30rpx;
  background: #eceff4;
  display: flex;
  align-items: center;
  justify-content: center;
}

.send-icon.disabled {
  opacity: 1;
}

.send-icon.loading {
  background: #eceff4;
}

.send-icon-text {
  font-size: 26rpx;
  color: #c4cbd6;
  transform: translateX(0);
}

.send-icon.active .send-icon-text {
  color: #7f8897;
}

.send-icon.loading .send-icon-text {
  color: #1f2937;
  font-size: 24rpx;
}

.input-tip {
  text-align: center;
  color: #98a1af;
  font-size: 22rpx;
  margin-bottom: 4rpx;
}
