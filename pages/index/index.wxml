<navigation-bar title="启小智" back="{{false}}" color="#1f2937" background="#f3f7ff"></navigation-bar>

<view class="page">
  <scroll-view class="scrollarea" scroll-y type="list">
    <view class="container">
      <block wx:if="{{messages.length === 0}}">
        <view class="hero-card">
          <view class="hero-top">
            <view>
              <view class="title">{{greeting}}，{{userName}}</view>
              <view class="desc">
                我是你的 AI 学习助手「{{assistantName}}」。可以为你推荐 AI 课程、检索学习资料、解答 AI 概念，也能基于当前课程出题练习。
              </view>
            </view>
            <view class="bot-avatar">🤖</view>
          </view>

          <view class="hint-row">
            <text class="hint-label">你可以这样问我：</text>
            <text class="switch-text">换一换</text>
          </view>

          <view class="suggestion-list">
            <view
              class="suggestion-item"
              wx:for="{{suggestions}}"
              wx:key="title"
              data-text="{{item.desc}}"
              bindtap="useSuggestion"
            >
              <view class="left">
                <text class="emoji">{{item.emoji}}</text>
                <text class="tag">{{item.title}}</text>
                <text class="s-text">{{item.desc}}</text>
              </view>
              <text class="arrow">›</text>
            </view>
          </view>
        </view>
      </block>

      <block wx:else>
        <view class="chat-list">
          <view class="msg {{item.role === 'user' ? 'user' : 'assistant'}}" wx:for="{{messages}}" wx:key="index">
            <text class="msg-text">{{item.content}}</text>
          </view>
          <view class="loading" wx:if="{{loading}}">正在思考中...</view>
        </view>
      </block>
    </view>
  </scroll-view>

  <view class="input-area">
    <textarea
      class="input"
      placeholder="您有什么想知道的，或输入 @ 选择技能来问我"
      value="{{inputText}}"
      maxlength="500"
      auto-height
      cursor-spacing="24"
      bindinput="onInput"
    />
    <view class="input-footer">
      <text class="counter">{{inputText.length}}/500</text>
      <button class="send-btn" bindtap="sendMessage" loading="{{loading}}" disabled="{{loading || !canSend}}">
        发送
      </button>
    </view>
  </view>
</view>
