<navigation-bar title="启小智" back="{{false}}" color="#1f2937" background="transparent"></navigation-bar>

<view class="page" bindtap="closeQuickActions">
  <scroll-view class="scrollarea" scroll-y type="list">
    <view class="page-container">
      <block wx:if="{{messages.length === 0}}">
        <view class="hero-card">
          <view class="hero-top">
            <view>
              <view class="title">{{greeting}}，{{userName}}</view>
              <view class="desc">
                我是你的 AI 学习助手「{{assistantName}}」。可以为你推荐 AI 课程、检索学习资料、解答 AI 概念，也能基于当前课程出题练习。
              </view>
            </view>
            <view class="bot-avatar">
              <view class="hi-badge">hi</view>
              <image class="bot-avatar-img" src="/assets/images/agent.jpg" mode="aspectFill" />
            </view>
          </view>

          <view class="hint-row">
            <text class="hint-label">你可以这样问我：</text>
            <view class="switch-action" bindtap="switchSuggestions">
              <text class="switch-icon">↻</text>
              <text class="switch-text">换一换</text>
            </view>
          </view>

          <view class="suggestion-list">
            <view
              class="suggestion-item"
              wx:for="{{suggestions}}"
              wx:key="title"
              data-text="{{item.desc}}"
              bindtap="useSuggestion"
            >
              <view class="left">
                <text class="emoji">{{item.emoji}}</text>
                <text class="tag">{{item.title}}</text>
                <text class="s-text">{{item.desc}}</text>
              </view>
              <text class="arrow">›</text>
            </view>
          </view>
        </view>
      </block>

      <block wx:else>
        <view class="chat-list">
          <view class="msg {{item.role === 'user' ? 'user' : 'assistant'}}" wx:for="{{messages}}" wx:key="index" wx:for-index="msgIndex">
            <view wx:if="{{item.role === 'assistant'}}" class="assistant-segments">
              <block wx:for="{{item.segments}}" wx:key="index" wx:for-index="segIndex">
                <rich-text wx:if="{{item.type === 'text'}}" class="msg-text" nodes="{{item.html}}"></rich-text>
                <view wx:elif="{{item.type === 'code'}}" class="code-card">
                  <view class="code-head">
                    <text class="code-lang">{{item.lang}}</text>
                    <text class="code-copy" data-msg-index="{{msgIndex}}" data-seg-index="{{segIndex}}" bindtap="onCopyCodeTap">复制</text>
                  </view>
                  <scroll-view scroll-x class="code-scroll">
                    <text class="code-body">{{item.code}}</text>
                  </scroll-view>
                </view>
              </block>
            </view>
            <rich-text
              wx:else
              class="msg-text user-msg-text"
              nodes="{{item.richText || item.content}}"
            ></rich-text>
          </view>
          <view class="loading" wx:if="{{loading}}">
            <text>正在思考中</text>
            <text class="dot dot1">.</text>
            <text class="dot dot2">.</text>
            <text class="dot dot3">.</text>
          </view>
        </view>
      </block>
    </view>
  </scroll-view>

  <view class="input-area" catchtap="noop">
    <view class="input-card">
      <textarea
        class="input"
        placeholder="您有什么想知道的，或输入 @ 选择技能来问问我"
        placeholder-style="color:#a8b1bd;font-size:29rpx;"
        value="{{inputText}}"
        maxlength="500"
        auto-height
        cursor-spacing="24"
        bindinput="onInput"
      />
      <view class="input-footer">
        <text class="counter">{{inputText.length}}/500</text>
        <view class="input-actions">
          <view class="plus-btn" catchtap="toggleQuickActions">＋</view>
          <view class="action-divider"></view>
          <view
            class="send-icon {{loading ? 'loading' : (canSend ? 'active' : 'disabled')}}"
            bindtap="handleSendButton"
          >
            <text class="send-icon-text">{{loading ? "■" : "➤"}}</text>
          </view>
        </view>
      </view>
    </view>
    <view class="quick-menu" wx:if="{{showQuickActions}}" catchtap="noop">
      <view class="quick-item" data-type="qa" bindtap="onQuickActionTap">
        <text class="quick-text">解题答疑</text>
      </view>
      <view class="quick-item" data-type="code" bindtap="onQuickActionTap">
        <text class="quick-text">编程</text>
      </view>
      <view class="quick-item" data-type="research" bindtap="onQuickActionTap">
        <text class="quick-text">深入研究</text>
      </view>
    </view>
    <view class="input-tip">内容由 AI 大模型生成，仅供参考</view>
  </view>
</view>
