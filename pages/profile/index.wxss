page {
  height: 100vh;
  background: #f5f6f8;
  color: #1f2937;
  display: flex;
  flex-direction: column;
}

.page {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  padding: 24rpx 24rpx 0;
  box-sizing: border-box;
}

.profile-main {
  flex: 1;
  min-height: 0;
  padding-top: 12rpx;
}

.login-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.login-left {
  display: flex;
  align-items: center;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
  background: #e6edf9;
  color: #5b6b85;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
}

.login-text {
  margin-left: 18rpx;
  font-size: 42rpx;
  font-weight: 700;
}

.settings-icon {
  font-size: 50rpx;
  color: #30363f;
  line-height: 1;
  padding: 8rpx;
}

.feature-card {
  margin-top: 20rpx;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
}

.feature-title {
  padding: 22rpx 24rpx;
  font-size: 44rpx;
  font-weight: 700;
  border-bottom: 1rpx solid #eceff3;
}

.feature-list {
  display: flex;
  align-items: stretch;
  padding: 12rpx 8rpx;
}

.feature-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 18rpx 10rpx 14rpx;
}

.feature-icon {
  font-size: 56rpx;
  line-height: 1;
}

.feature-text {
  font-size: 34rpx;
  color: #2f3640;
}

.profile-footer {
  margin-top: auto;
  padding: 12rpx 0 10rpx;
  flex: none;
  background: transparent;
}

.logout-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 20rpx;
  background: #ffffff;
  color: #646b75;
  font-size: 42rpx;
}