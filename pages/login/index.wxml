<navigation-bar title="登录" back="{{true}}" color="#1f2937" background="#ffffff"></navigation-bar>

<view class="page">
  <view class="card">
    <input class="input" placeholder="请输入用户名（至少3位）" value="{{username}}" bindinput="onUsernameInput" />
    <input class="input" password placeholder="请输入密码（至少6位）" value="{{password}}" bindinput="onPasswordInput" />
    <view class="btn-row">
      <button class="btn secondary" bindtap="onRegister" loading="{{loading}}" disabled="{{loading}}">注册</button>
      <button class="btn primary" bindtap="onLogin" loading="{{loading}}" disabled="{{loading}}">登录</button>
    </view>
  </view>
</view>
<!--pages/login/index.wxml-->
<text>pages/login/index.wxml</text>